{
  "name": "superclaw-setup",
  "productName": "SuperClaw",
  "version": "1.0.2",
  "description": "SuperClaw セットアップ — ワンクリックでインストール",
  "main": "src/main/index.js",
  "author": "SuperClaw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheOnlySean/superclaw-macos.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:mac:arm64": "TARGET_ARCH=arm64 npm run prepare-openclaw && npm run prepare-node-runtime:arm64 && electron-builder --mac --arm64",
    "dist:mac:arm64:signed": "TARGET_ARCH=arm64 npm run prepare-openclaw && npm run prepare-node-runtime:arm64 && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --dir && node scripts/sign-mac-app.js && node scripts/create-dmg.js",
    "dist:mac:arm64:dir": "npm run prepare-node-runtime:arm64 && electron-builder --mac --arm64 --dir",
    "sign-mac-app": "node scripts/sign-mac-app.js",
    "create-dmg": "node scripts/create-dmg.js",
    "dist:mac:arm64:safe": "npm run dist:mac:arm64:dir && npm run create-dmg",
    "dist:mac:x64": "electron-builder --mac --x64",
    "dist:win": "electron-builder --win",
    "prepare-control-ui-ja": "node scripts/prepare-control-ui-ja.js",
    "prepare-openclaw": "node scripts/bundle-openclaw.js",
    "prepare-node-runtime": "node scripts/prepare-node-runtime.js",
    "prepare-node-runtime:arm64": "node scripts/prepare-node-runtime.js darwin-arm64",
    "prepare-node-runtime:x64": "node scripts/prepare-node-runtime.js darwin-x64",
    "prepare-all": "npm run prepare-openclaw && npm run prepare-node-runtime:arm64",
    "dist:mac:x64:dir": "npm run prepare-openclaw && npm run prepare-node-runtime:x64 && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --x64 --dir",
    "dist:mac:x64:signed": "npm run dist:mac:x64:dir && MAC_ARCH=x64 node scripts/sign-mac-app.js",
    "check-notarize": "node scripts/check-notarize-status.js",
    "test:dashboard-csp:block": "TEST_DASHBOARD_CSP=block electron .",
    "test:dashboard-csp:allow": "TEST_DASHBOARD_CSP=allow electron .",
    "test:app-protocol": "electron scripts/test-app-protocol-main.js",
    "test:dashboard-http": "node scripts/test-dashboard-http-server-only.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "24.9.1"
  },
  "overrides": {
    "js-yaml": "3.14.2"
  },
  "build": {
    "appId": "ai.superclaw.setup",
    "productName": "SuperClaw",
    "afterPack": "scripts/afterPack.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "locales/**/*",
      "build/**/*",
      "scripts/codex-oauth-standalone.js",
      "scripts/qwen-oauth-standalone.js"
    ],
    "asarUnpack": [
      "**/src/main/**",
      "**/src/renderer/**",
      "**/scripts/codex-oauth-standalone.js",
      "**/scripts/qwen-oauth-standalone.js"
    ],
    "extraResources": [
      "control-ui-ja",
      "dashboard-renderer",
      "openclaw",
      "node-runtime"
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icons/icon-512.png",
      "target": [
        "dmg",
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "SuperClaw セットアップ"
    },
    "win": {
      "icon": "build/icons/icon-512.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
